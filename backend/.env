# ─────────────────────────────
# SERVER CONFIG
# ─────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────
# DATABASE (MongoDB)
# ─────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/mood-detector

# ─────────────────────────────
# FRONTEND URL (React Vite)
# ─────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────
# SECURITY (optional nanti)
# ─────────────────────────────
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=7d

# ─────────────────────────────
# UPLOAD CONFIG (kalau pakai multer)
# ─────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
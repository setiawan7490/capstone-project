
# ─────────────────────────────
# SERVER CONFIG
# ─────────────────────────────
#PORT=5000
#NODE_ENV=development

# ─────────────────────────────
# DATABASE (MongoDB)
# ─────────────────────────────
#MONGODB_URI=mongodb://127.0.0.1:27017/mood-detector

# ─────────────────────────────
# FRONTEND URL (React Vite)
# ─────────────────────────────
#FRONTEND_URL=http://localhost:5173

# ─────────────────────────────
# SECURITY (optional nanti)
# ─────────────────────────────
#JWT_SECRET=supersecretkey
#JWT_EXPIRES_IN=7d

# ─────────────────────────────
# UPLOAD CONFIG (kalau pakai multer)
# ─────────────────────────────
#MAX_FILE_SIZE=5242880
#UPLOAD_DIR=uploads

cat > /home/claude/backend/.env.example << 'EOF'
# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────
# Pilih SALAH SATU:
#
# Opsi A — MongoDB Atlas (ONLINE, GRATIS, DIREKOMENDASIKAN):
# 1. Buka https://cloud.mongodb.com dan buat akun gratis
# 2. Buat cluster baru → pilih "M0 Free" (gratis selamanya)
# 3. Database Access → Add New User → buat username & password
# 4. Network Access → Add IP Address → Allow Access from Anywhere (0.0.0.0/0)
# 5. Database → Connect → Drivers → salin connection string
# 6. Ganti <username> <password> di bawah:
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mood-detector?retryWrites=true&w=majority

# Opsi B — MongoDB Lokal (perlu MongoDB terinstall):
# MONGODB_URI=mongodb://localhost:27017/mood-detector

# ── Frontend URL (untuk CORS) ────────────────────────
FRONTEND_URL=http://localhost:5173
EOF